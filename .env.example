# 복사해서 .env로 만들고 본인 값으로 바꾸세요
GARMIN_USER=your_garmin_email@example.com
GARMIN_PASS=your_garmin_password
DRIVE_PARENT_FOLDER_ID=    # (선택) My Drive 아래에 업로드할 부모 폴더 id
WORKDIR=/Users/YOUR_USERNAME/garmin-drive-sync
TELEGRAM_BOT_TOKEN=            # Telegram bot token (BotFather)
TELEGRAM_OWNER_ID=             # Telegram 봇 소유자 user ID (숫자). /start 시 안내됨
HR_ZONE2_LOW=137               # Zone2 심박수 하한 (기본 137)
HR_ZONE2_HIGH=156              # Zone2 심박수 상한 (기본 156)
