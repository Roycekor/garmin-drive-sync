<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.garmin-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/YOUR_USERNAME/garmin-drive-sync/venv/bin/python3</string>
    <string>/Users/YOUR_USERNAME/garmin-drive-sync/scripts/main.py</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>21600</integer>

  <key>WorkingDirectory</key>
  <string>/Users/YOUR_USERNAME/garmin-drive-sync</string>

  <key>StandardOutPath</key>
  <string>/Users/YOUR_USERNAME/garmin-drive-sync/logs/launch_stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOUR_USERNAME/garmin-drive-sync/logs/launch_stderr.log</string>
</dict>
</plist>
